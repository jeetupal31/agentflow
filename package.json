{
  "name": "agentflow",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "marked": "^18.0.5",
    "puppeteer": "^25.1.0",
    "turbo": "^2.3.3"
  },
  "dependencies": {
    "mongodb-memory-server": "^11.2.0"
  }
}
