{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_AUTH_URL": "@agentflow_auth_url",
    "NEXT_PUBLIC_WORKFLOW_URL": "@agentflow_workflow_url",
    "NEXT_PUBLIC_ENGINE_URL": "@agentflow_engine_url"
  }
}
